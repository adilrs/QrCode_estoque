# Configurações do Banco de Dados Firebird
# Copie este arquivo para .env e ajuste os valores conforme necessário

# Caminho para o arquivo do banco de dados
DB_PATH=e:/gdb/retesp.fdb

# Endereço IP ou hostname do servidor Firebird
DB_HOST=192.168.0.8

# Usuário do banco de dados
DB_USER=SYSDBA

# Senha do banco de dados (ALTERE ESTA SENHA!)
DB_PASSWORD=a

# Codificação do banco de dados
DB_ENCODING=LATIN1

# Configurações do Flask
# Defina como 'false' em produção
FLASK_DEBUG=false

# Porta do servidor (padrão: 5000)
FLASK_PORT=5000

# Host do servidor (0.0.0.0 para aceitar conexões externas)
FLASK_HOST=0.0.0.0

# Configurações SSL (opcional)
# Caminhos para os certificados SSL
SSL_CERT=cert.pem
SSL_KEY=key.pem

# Configurações de Logging
# Níveis disponíveis: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO